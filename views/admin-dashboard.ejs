<%- include('partials/header') %>
    <section>
        <div class="section-head">
            <h1>Admin Dashboard</h1>
            <p>Welcome, <%= user.fullname %>. Monitor activity and charts.</p>
        </div>
        <div class="stats-grid">
            <div class="stat-card"><span>Users</span><strong>
                    <%= stats.usersCount %>
                </strong></div>
            <div class="stat-card"><span>Contacts</span><strong>
                    <%= stats.contactsCount %>
                </strong></div>
            <div class="stat-card"><span>Opportunities</span><strong>
                    <%= stats.opportunitiesCount %>
                </strong></div>
            <div class="stat-card"><span>Applications</span><strong>
                    <%= stats.appsCount %>
                </strong></div>
        </div>
        <div class="hero-actions"><a class="btn-primary" href="/crm">Open CRM</a><a class="btn-secondary"
                href="/manage/opportunity/new">Add Opportunity</a></div>
        <div class="chart-grid">
            <div class="chart-card">
                <h3>By category</h3><canvas id="catChart"></canvas>
            </div>
            <div class="chart-card">
                <h3>Applications by status</h3><canvas id="statusChart"></canvas>
            </div>
            <div class="chart-card full">
                <h3>Top locations</h3><canvas id="locChart"></canvas>
            </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>window.dashboardCharts = true;</script>
    </section><%- include('partials/footer') %>