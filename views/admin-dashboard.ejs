<%- include('partials/header', { currentPage }) %>

<section class="dashboard-page">
  <div class="dashboard-hero">
    <h2>Admin Dashboard</h2>
    <p>
      Welcome back, <%= user.fullname %>. Monitor platform growth, review core activity,
      and manage users, opportunities, and contact requests from one clean workspace.
    </p>
  </div>

  <section class="stats-grid admin-stats">
    <div class="stat-card admin-stat-card">
      <div class="stat-icon">👥</div>
      <div>
        <h3><%= stats.usersCount %></h3>
        <p>Total Users</p>
      </div>
    </div>

    <div class="stat-card admin-stat-card">
      <div class="stat-icon">📨</div>
      <div>
        <h3><%= stats.contactsCount %></h3>
        <p>Contact Messages</p>
      </div>
    </div>

    <div class="stat-card admin-stat-card">
      <div class="stat-icon">💼</div>
      <div>
        <h3><%= stats.opportunitiesCount %></h3>
        <p>Total Opportunities</p>
      </div>
    </div>
  </section>

  <section class="quick-actions">

  <a href="/crm" class="quick-action-card">
    <span class="action-icon">➕</span>
    <h3>Add Opportunity</h3>
    <p>Create a new job, internship or project.</p>
  </a>

  <a href="/crm" class="quick-action-card">
    <span class="action-icon">👥</span>
    <h3>Manage Users</h3>
    <p>Review and manage platform users.</p>
  </a>

  <a href="/crm" class="quick-action-card">
    <span class="action-icon">📨</span>
    <h3>View Messages</h3>
    <p>Check contact requests and feedback.</p>
  </a>

</section>

  <section class="dashboard-grid">

  <div class="dashboard-card">
    <div class="action-icon">👥</div>
    <h3>Users Management</h3>
    <p>Manage students, graduates, employers and administrators.</p>
    <a href="/crm" class="btn-link dashboard-btn">
      Manage Users
    </a>
  </div>

  <div class="dashboard-card">
    <div class="action-icon">💼</div>
    <h3>Opportunities</h3>
    <p>Manage jobs, internships and projects published on the platform.</p>
    <a href="/crm" class="btn-link dashboard-btn">
      View Opportunities
    </a>
  </div>

  <div class="dashboard-card">
    <div class="action-icon">📨</div>
    <h3>Messages Center</h3>
    <p>Review contact requests and user inquiries.</p>
    <a href="/crm" class="btn-link dashboard-btn">
      View Messages
    </a>
  </div>

  <div class="dashboard-card">
    <div class="action-icon">📊</div>
    <h3>Analytics</h3>
    <p>Track platform activity and monitor growth metrics.</p>
    <a href="#" class="btn-link dashboard-btn">
      Coming Soon
    </a>
  </div>

</section>
<section class="recent-activity">
  <div class="section-toolbar">
    <div>
      <h2>Recent Activity</h2>
      <p>Latest platform activity and admin updates.</p>
    </div>
  </div>

  <div class="activity-list">
    <div class="activity-item">
      <span class="activity-icon">👤</span>
      <div>
        <strong>Users management is active</strong>
        <p>Admins can review users through the CRM workspace.</p>
      </div>
    </div>

    <div class="activity-item">
      <span class="activity-icon">💼</span>
      <div>
        <strong><%= stats.opportunitiesCount %> opportunities available</strong>
        <p>Jobs, internships and projects are currently published.</p>
      </div>
    </div>

    <div class="activity-item">
      <span class="activity-icon">📨</span>
      <div>
        <strong><%= stats.contactsCount %> contact messages</strong>
        <p>Contact requests can be monitored from the CRM dashboard.</p>
      </div>
    </div>
  </div>
</section>

</section>

<%- include('partials/footer') %>

