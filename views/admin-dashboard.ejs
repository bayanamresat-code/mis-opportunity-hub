<%- include('partials/header', { currentPage, currentUser }) %>
    <div class="container">
        <div class="section-head">
            <div>
                <h1>Admin Dashboard</h1>
                <p>Monitor users, CRM activity, and application performance.</p>
            </div>
            <div class="toolbar"><a class="btn btn-primary" href="/crm">Open CRM</a><a class="btn btn-secondary"
                    href="/manage/opportunity/new">Add Opportunity</a></div>
        </div>
        <section class="grid-4">
            <div class="stat-card kpi"><span>Users</span><strong>
                    <%= stats.usersCount %>
                </strong></div>
            <div class="stat-card kpi"><span>Contacts</span><strong>
                    <%= stats.contactsCount %>
                </strong></div>
            <div class="stat-card kpi"><span>Opportunities</span><strong>
                    <%= stats.opportunitiesCount %>
                </strong></div>
            <div class="stat-card kpi"><span>Applications</span><strong>
                    <%= stats.appsCount %>
                </strong></div>
        </section>
        <div class="grid-3" style="margin-top:24px;">
            <section class="card">
                <h3>By category</h3>
                <% byCategory.forEach(row=> { %><p><strong>
                            <%= row.category %>
                        </strong>: <%= row.total %>
                    </p>
                    <% }) %>
            </section>
            <section class="card">
                <h3>Application status</h3>
                <% byStatus.forEach(row=> { %><p><strong>
                            <%= row.status %>
                        </strong>: <%= row.total %>
                    </p>
                    <% }) %>
            </section>
            <section class="card">
                <h3>Top locations</h3>
                <% byLocation.forEach(row=> { %><p><strong>
                            <%= row.location %>
                        </strong>: <%= row.total %>
                    </p>
                    <% }) %>
            </section>
        </div>
        <div class="section-head" style="margin-top:24px;">
            <div>
                <h2>Latest users</h2>
                <p>Recently created accounts across all roles.</p>
            </div>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    <% latestUsers.forEach(u=> { %><tr>
                            <td>
                                <%= u.fullname %>
                            </td>
                            <td>
                                <%= u.email %>
                            </td>
                            <td>
                                <%= u.role %>
                            </td>
                            <td>
                                <%= new Date(u.created_at).toLocaleDateString() %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <%- include('partials/footer') %>