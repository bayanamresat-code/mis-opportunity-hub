<%- include('partials/header', { currentPage }) %>

  <section class="hero">
    <div class="hero-text">
      <h1>Opportunity Hub</h1>
      <p>
        A smart platform that connects students, graduates, employers, and academic opportunities in one place.
        Explore jobs, internships, projects, and employer connections designed to support career growth and professional
        development.
      </p>
      <a href="/jobs" class="btn">Browse Opportunities</a>
    </div>
  </section>

  <section class="about">
  <h2>Featured Employers</h2>
  <p>Explore employers connected to the platform.</p>

  <% if (!employers || employers.length === 0) { %>
    <p>No employers available at the moment.</p>
  <% } else { %>
    <div class="crm-table-wrapper">
      <table class="crm-table">
        <thead>
          <tr>
            <th>Company</th>
            <th>Industry</th>
            <th>Contact Role</th>
            <th>Contact Name</th>
            <th>Phone</th>
            <th>Email</th>
          </tr>
        </thead>
        <tbody>
          <% employers.forEach(employer => { %>
            <tr>
              <td><%= employer.company_name %></td>
              <td><%= employer.industry || 'N/A' %></td>
              <td><%= employer.contact_role || 'N/A' %></td>
              <td><%= employer.contact_name || 'N/A' %></td>
              <td><%= employer.phone || 'N/A' %></td>
              <td><%= employer.email || 'N/A' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

  <section class="features">
    <div class="feature-card">
      <h3>Jobs</h3>
      <p>Browse job opportunities that match the academic background and technical skills of Information Systems
        students and graduates.</p>
      <a href="/jobs" class="btn secondary">View Jobs</a>
    </div>

    <div class="feature-card">
      <h3>Internships</h3>
      <p>Find internships that provide real-world experience, professional exposure, and a practical bridge between
        studies and the workplace.</p>
      <a href="/internships" class="btn secondary">View Internships</a>
    </div>

    <div class="feature-card">
      <h3>Projects</h3>
      <p>Explore academic and industry projects that can help build experience, improve portfolios, and create
        meaningful collaboration opportunities.</p>
      <a href="/projects" class="btn secondary">View Projects</a>
    </div>
  </section>

  <section class="about">
    <h2>Who Is It For?</h2>
    <p>
      The platform is designed for students looking for practical experience, graduates seeking career opportunities,
      and employers who want to connect with qualified candidates in the Information Systems field.
    </p>

    <div class="features">
      <div class="feature-card">
        <h3>Students</h3>
        <p>Discover internships, projects, and entry-level opportunities that support learning and skill development.
        </p>
      </div>

      <div class="feature-card">
        <h3>Graduates</h3>
        <p>Access professional opportunities and continue building your career with relevant roles and projects.</p>
      </div>

      <div class="feature-card">
        <h3>Employers</h3>
        <p>Reach motivated students and graduates and build connections through one centralized opportunity hub.</p>
      </div>
    </div>
  </section>

  <section class="about">
    <h2>Featured Employers</h2>
    <p>
      Explore employers from industry, software, manufacturing, analytics, operations, and technology who can connect
      with students and graduates.
    </p>

    <% if (!employers || employers.length===0) { %>
      <p>No employers available at the moment.</p>
      <% } else { %>
        <div class="crm-table-wrapper">
          <table class="crm-table">
            <thead>
              <tr>
                <th>Company</th>
                <th>Industry</th>
                <th>Contact Role</th>
                <th>Contact Name</th>
                <th>Phone</th>
                <th>Email</th>
              </tr>
            </thead>
            <tbody>
              <% employers.forEach(employer=> { %>
                <tr>
                  <td><strong>
                      <%= employer.company_name %>
                    </strong></td>
                  <td>
                    <%= employer.industry || 'N/A' %>
                  </td>
                  <td>
                    <%= employer.contact_role || 'N/A' %>
                  </td>
                  <td>
                    <%= employer.contact_name || 'N/A' %>
                  </td>
                  <td>
                    <%= employer.phone || 'N/A' %>
                  </td>
                  <td>
                    <% if (employer.email) { %>
                      <a href="mailto:<%= employer.email %>">
                        <%= employer.email %>
                      </a>
                      <% } else { %>
                        N/A
                        <% } %>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
  </section>

  <section class="about">
    <h2>Start Your Next Step</h2>
    <p>
      Whether you are looking for your first internship, your next job, or a project to strengthen your portfolio,
      Opportunity Hub gives you one place to begin.
    </p>
  </section>

  <%- include('partials/footer') %>