<%- include('partials/header', { currentPage: 'search' }) %>

<section class="jobs-page search-page">
  <div class="jobs-header">
    <h2>Advanced Search</h2>
    <p>Find jobs, internships, and projects using smart filters.</p>
  </div>

  <section class="search-card">
    <form action="/search" method="GET" class="search-form">
      <div class="form-group">
        <label for="q">Keyword</label>
        <input type="text" id="q" name="q" value="<%= filters.q %>"
          placeholder="Search by title, company, or description">
      </div>

      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category">
          <option value="">All categories</option>
          <option value="job" <%= filters.category === 'job' ? 'selected' : '' %>>Job</option>
          <option value="internship" <%= filters.category === 'internship' ? 'selected' : '' %>>Internship</option>
          <option value="project" <%= filters.category === 'project' ? 'selected' : '' %>>Project</option>
        </select>
      </div>

      <div class="form-group">
        <label for="location">Location</label>
        <input type="text" id="location" name="location" value="<%= filters.location %>"
          placeholder="e.g. Haifa">
      </div>

      <div class="form-group">
        <label for="company">Company</label>
        <input type="text" id="company" name="company" value="<%= filters.company %>"
          placeholder="e.g. Elbit">
      </div>

      <div class="form-group">
        <label for="status">Status</label>
        <select id="status" name="status">
          <option value="">All statuses</option>
          <option value="open" <%= filters.status === 'open' ? 'selected' : '' %>>Open</option>
          <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Closed</option>
          <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
        </select>
      </div>

      <div class="form-actions search-actions">
        <button type="submit" class="btn search-btn">Search</button>
        <a href="/search" class="reset-btn">Reset</a>
      </div>
    </form>
  </section>

  <section class="results-section">
    <div class="results-header">
      <h2>Results (<%= items.length %>)</h2>
      <p>Browse matching opportunities below.</p>
    </div>

    <% if (!items || items.length === 0) { %>
      <div class="empty-state">
        <h3>No matching opportunities found</h3>
        <p>Try changing the keyword, category, location, or status filter.</p>
      </div>
    <% } else { %>
      <div class="cards-grid">
        <% items.forEach(item => { %>
          <article class="opportunity-card">
            <div class="card-header">
              <span class="job-badge"><%= item.category || 'opportunity' %></span>
              <span class="status-badge"><%= item.status || 'open' %></span>
            </div>

            <h3 class="job-title"><%= item.title %></h3>

            <p class="company-name">
              <%= item.company || 'Company not specified' %>
            </p>

            <div class="job-meta">
              <span>📍 <%= item.location || 'Location not specified' %></span>
            </div>

            <p class="job-description">
              <%= item.description || 'No description available.' %>
            </p>

            <div class="contact-section">
              <p><strong>Category:</strong> <%= item.category || 'N/A' %></p>
              <p><strong>Status:</strong> <%= item.status || 'open' %></p>
            </div>

            <div class="card-actions">
              <a href="mailto:<%= item.contact_email || '' %>" class="btn apply-btn">
                Apply Now
              </a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</section>

<%- include('partials/footer') %>