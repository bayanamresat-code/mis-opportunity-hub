<%- include('partials/header', { currentPage, currentUser }) %>
  <div class="container">
    <div class="section-head">
      <div>
        <h1>Advanced Search</h1>
        <p>Filter by keyword, city, category, and status.</p>
      </div>
    </div>
    <section class="panel">
      <form class="stack" method="GET" action="/search">
        <div class="form-grid">
          <input type="text" name="q" value="<%= filters.q %>" placeholder="Keyword" />
          <input type="text" name="location" value="<%= filters.location %>" placeholder="Location" />
          <select name="category">
            <option value="">All categories</option>
            <option value="job" <%=filters.category==='job' ? 'selected' : '' %>>Job</option>
            <option value="internship" <%=filters.category==='internship' ? 'selected' : '' %>>Internship</option>
            <option value="project" <%=filters.category==='project' ? 'selected' : '' %>>Project</option>
          </select>
          <select name="status">
            <option value="">All statuses</option>
            <option value="open" <%=filters.status==='open' ? 'selected' : '' %>>Open</option>
            <option value="closed" <%=filters.status==='closed' ? 'selected' : '' %>>Closed</option>
            <option value="draft" <%=filters.status==='draft' ? 'selected' : '' %>>Draft</option>
          </select>
        </div>
        <div class="toolbar"><button class="btn btn-primary">Search</button><a class="btn btn-secondary"
            href="/search">Reset</a></div>
      </form>
    </section>
    <div class="list-grid" style="margin-top:18px;">
      <% if (!items.length) { %>
        <div class="card empty">No opportunities matched your filters.</div>
        <% } %>
          <% items.forEach(item=> { %>
            <article class="card">
              <span class="badge">
                <%= item.category %>
              </span>
              <h3>
                <%= item.title %>
              </h3>
              <p><strong>Company:</strong>
                <%= item.company_name || '—' %>
              </p>
              <p><strong>Location:</strong>
                <%= item.location %>
              </p>
              <p><strong>Status:</strong>
                <%= item.status %>
              </p>
              <p class="muted">
                <%= item.description %>
              </p>
            </article>
            <% }) %>
    </div>
  </div>
  <%- include('partials/footer') %>