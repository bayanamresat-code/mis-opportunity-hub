<%- include('partials/header', { currentPage }) %>

<section class="crm-page">
  <div class="jobs-header">
    <h2>CRM Dashboard</h2>
    <p>A clean workspace for managing users, opportunities, and contact messages across the platform.</p>
  </div>

  <section class="stats-grid">
    <div class="stat-card">
      <h3><%= users ? users.length : 0 %></h3>
      <p>Total users</p>
    </div>
    <div class="stat-card">
      <h3><%= opportunities ? opportunities.length : 0 %></h3>
      <p>Open opportunities</p>
    </div>
    <div class="stat-card">
      <h3><%= contacts ? contacts.length : 0 %></h3>
      <p>Contact requests</p>
    </div>
    <div class="stat-card">
      <h3><%= users ? users.filter(u => u.role === 'employer').length : 0 %></h3>
      <p>Employers</p>
    </div>
  </section>

  <section class="about">
    <div class="section-toolbar">
      <div>
        <h3>Users</h3>
        <p>Manage registered accounts and review user roles.</p>
      </div>
      <span class="section-count"><%= users ? users.length : 0 %> records</span>
    </div>

    <% if (!users || users.length === 0) { %>
      <p>No users available.</p>
    <% } else { %>
      <div class="table-tools">
        <input type="text" class="table-search" data-table-search="users-table" placeholder="Search users...">
      </div>

      <div class="crm-table-wrapper">
        <table class="crm-table" id="users-table">
          <thead>
            <tr>
              <th>Full name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td><span class="cell-title"><%= user.fullname %></span></td>
                <td><%= user.email %></td>
                <td><span class="badge badge-<%= user.role %>"><%= user.role %></span></td>
                <td><%= user.created_at || 'N/A' %></td>
                <td>
                  <div class="table-actions">
                    <button type="button" class="action-btn edit">Edit</button>

                    <form
                      class="inline-form"
                      action="/delete-user/<%= user.id %>"
                      method="POST"
                      onsubmit="return confirm('Delete user <%= user.fullname %>?')">
                      <button type="submit" class="action-btn delete">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>

  <section class="about">
    <div class="section-toolbar">
      <div>
        <h3>Opportunities</h3>
        <p>Track jobs, internships, and projects published on the platform.</p>
      </div>
      <span class="section-count"><%= opportunities ? opportunities.length : 0 %> records</span>
    </div>

    <% if (!opportunities || opportunities.length === 0) { %>
      <p>No opportunities available.</p>
    <% } else { %>
      <div class="table-tools">
        <input type="text" class="table-search" data-table-search="opportunities-table" placeholder="Search opportunities...">
      </div>

      <div class="crm-table-wrapper">
        <table class="crm-table" id="opportunities-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Location</th>
              <th>Category</th>
              <th>Description</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% opportunities.forEach(item => { %>
              <tr>
                <td><span class="cell-title"><%= item.title %></span></td>
                <td><%= item.location %></td>
                <td><span class="badge badge-<%= item.category %>"><%= item.category %></span></td>
                <td><%= item.description %></td>
                <td><%= item.created_at || 'N/A' %></td>
                <td>
                  <div class="table-actions">
                    <a href="/edit-opportunity/<%= item.id %>" class="action-btn edit">Edit</a>

                    <form
                      class="inline-form"
                      action="/delete-opportunity/<%= item.id %>"
                      method="POST"
                      onsubmit="return confirm('Delete opportunity <%= item.title %>?')">
                      <button type="submit" class="action-btn delete">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>

  <section class="about">
    <div class="section-toolbar">
      <div>
        <h3>Contacts</h3>
        <p>Review inbound messages and follow up with senders.</p>
      </div>
      <span class="section-count"><%= contacts ? contacts.length : 0 %> records</span>
    </div>

    <% if (!contacts || contacts.length === 0) { %>
      <p>No contact messages available.</p>
    <% } else { %>
      <div class="table-tools">
        <input type="text" class="table-search" data-table-search="contacts-table" placeholder="Search contacts...">
      </div>

      <div class="crm-table-wrapper">
        <table class="crm-table" id="contacts-table">
          <thead>
            <tr>
              <th>Subject</th>
              <th>Name</th>
              <th>Email</th>
              <th>Message</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% contacts.forEach(contact => { %>
              <tr>
                <td><span class="cell-title"><%= contact.subject %></span></td>
                <td><%= contact.name %></td>
                <td><%= contact.email %></td>
                <td><%= contact.message %></td>
                <td><%= contact.created_at || 'N/A' %></td>
                <td>
                  <div class="table-actions">
                    <button type="button" class="action-btn edit">View</button>

                    <form
                      class="inline-form"
                      action="/delete-contact/<%= contact.id %>"
                      method="POST"
                      onsubmit="return confirm('Delete this contact message from <%= contact.name %>?')">
                      <button type="submit" class="action-btn delete">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</section>

<script>
  document.querySelectorAll('[data-table-search]').forEach(input => {
    input.addEventListener('input', function () {
      const tableId = this.getAttribute('data-table-search');
      const table = document.getElementById(tableId);
      if (!table) return;

      const rows = table.querySelectorAll('tbody tr');
      const value = this.value.toLowerCase().trim();

      rows.forEach(row => {
        const text = row.innerText.toLowerCase();
        row.style.display = text.includes(value) ? '' : 'none';
      });
    });
  });
</script>

<%- include('partials/footer') %>