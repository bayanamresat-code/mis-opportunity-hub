<%- include('partials/header', { currentPage }) %>
  <section class="page-shell section-block">
    <div class="section-head">
      <h1>CRM Panel</h1>
      <p>Manage users, opportunities, contacts, and application flow.</p>
    </div>
    <% if (errorMessage) { %>
      <p class="flash error">
        <%= errorMessage %>
      </p>
      <% } %>

        <section class="crm-section">
          <div class="section-title-row">
            <h2>Users</h2><span class="count-badge">
              <%= users.length %>
            </span>
          </div>
          <div class="table-wrap">
            <table class="crm-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Created</th>
                </tr>
              </thead>
              <tbody>
                <% if (!users.length) { %>
                  <tr>
                    <td colspan="5">No users available.</td>
                  </tr>
                  <% } %>
                    <% users.forEach(user=> { %><tr>
                        <td>
                          <%= user.id %>
                        </td>
                        <td>
                          <%= user.fullname %>
                        </td>
                        <td>
                          <%= user.email %>
                        </td>
                        <td><span class="badge">
                            <%= user.role %>
                          </span></td>
                        <td>
                          <%= user.created_at %>
                        </td>
                      </tr>
                      <% }) %>
              </tbody>
            </table>
          </div>
        </section>

        <section class="crm-section">
          <div class="section-title-row">
            <h2>Applications</h2><span class="count-badge">
              <%= applications.length %>
            </span>
          </div>
          <div class="table-wrap">
            <table class="crm-table">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Email</th>
                  <th>Opportunity</th>
                  <th>Category</th>
                  <th>Status</th>
                  <th>Notes</th>
                </tr>
              </thead>
              <tbody>
                <% if (!applications.length) { %>
                  <tr>
                    <td colspan="6">No applications found.</td>
                  </tr>
                  <% } %>
                    <% applications.forEach(app=> { %><tr>
                        <td>
                          <%= app.fullname %>
                        </td>
                        <td>
                          <%= app.email %>
                        </td>
                        <td>
                          <%= app.title %>
                        </td>
                        <td>
                          <%= app.category %>
                        </td>
                        <td>
                          <%= app.status %>
                        </td>
                        <td>
                          <%= app.notes || '-' %>
                        </td>
                      </tr>
                      <% }) %>
              </tbody>
            </table>
          </div>
        </section>

        <section class="crm-section">
          <div class="section-title-row">
            <h2>Opportunities</h2><span class="count-badge">
              <%= opportunities.length %>
            </span>
          </div>
          <div class="card-grid">
            <% opportunities.forEach(item=> { %>
              <article class="card">
                <span class="badge">
                  <%= item.category %>
                </span>
                <h3>
                  <%= item.title %>
                </h3>
                <p><strong>Location:</strong>
                  <%= item.location %>
                </p>
                <p><strong>Status:</strong>
                  <%= item.status %>
                </p>
                <p>
                  <%= item.description %>
                </p>
                <div class="hero-actions compact-actions">
                  <a class="btn-secondary" href="/manage/opportunity/<%= item.id %>/edit">Edit</a>
                  <form method="POST" action="/manage/opportunity/<%= item.id %>/delete"
                    onsubmit="return confirm('Delete this opportunity?');"><button class="btn-primary">Delete</button>
                  </form>
                </div>
              </article>
              <% }) %>
          </div>
        </section>

        <section class="crm-section">
          <div class="section-title-row">
            <h2>Contacts</h2><span class="count-badge">
              <%= contacts.length %>
            </span>
          </div>
          <div class="card-grid">
            <% if (!contacts.length) { %>
              <p class="empty">No contact messages available.</p>
              <% } %>
                <% contacts.forEach(contact=> { %><article class="card">
                    <h3>
                      <%= contact.subject %>
                    </h3>
                    <p><strong>Name:</strong>
                      <%= contact.name %>
                    </p>
                    <p><strong>Email:</strong>
                      <%= contact.email %>
                    </p>
                    <p>
                      <%= contact.message %>
                    </p>
                  </article>
                  <% }) %>
          </div>
        </section>
  </section>
  <%- include('partials/footer') %>