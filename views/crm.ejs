<%- include('partials/header') %>
    <section>
        <div class="section-head">
            <h1>CRM Panel</h1>
            <p>Manage users, opportunities, contacts, and application flow.</p>
        </div>
        <section>
            <h2>Applications</h2>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Opportunity</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Update</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% applications.forEach(app=> { %><tr>
                                <td>
                                    <%= app.fullname %>
                                </td>
                                <td>
                                    <%= app.email %>
                                </td>
                                <td>
                                    <%= app.title %>
                                </td>
                                <td>
                                    <%= app.category %>
                                </td>
                                <td><span class="badge">
                                        <%= app.status %>
                                    </span></td>
                                <td>
                                    <form class="inline-form" method="POST" action="/applications/<%= app.id %>/status">
                                        <select name="status">
                                            <option value="pending">pending</option>
                                            <option value="accepted">accepted</option>
                                            <option value="rejected">rejected</option>
                                            <option value="in_progress">in_progress</option>
                                            <option value="completed">completed</option>
                                        </select><input name="notes" placeholder="Notes"
                                            value="<%= app.notes || '' %>" /><button class="btn-primary">Save</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </section>
        <section>
            <h2>Opportunities</h2>
            <div class="card-grid">
                <% opportunities.forEach(item=> { %><article class="card"><span class="badge">
                            <%= item.category %>
                        </span>
                        <h3>
                            <%= item.title %>
                        </h3>
                        <p><strong>Location:</strong>
                            <%= item.location %>
                        </p>
                        <p><strong>Status:</strong>
                            <%= item.status %>
                        </p>
                        <p>
                            <%= item.description %>
                        </p>
                        <div class="inline-actions"><a class="btn-secondary"
                                href="/manage/opportunity/<%= item.id %>/edit">Edit</a>
                            <form method="POST" action="/manage/opportunity/<%= item.id %>/delete"><button
                                    class="btn-danger">Delete</button></form>
                        </div>
                    </article>
                    <% }) %>
            </div>
        </section>
        <section>
            <h2>Contacts</h2>
            <div class="card-grid">
                <% contacts.forEach(contact=> { %><article class="card">
                        <h3>
                            <%= contact.subject %>
                        </h3>
                        <p><strong>Name:</strong>
                            <%= contact.name %>
                        </p>
                        <p><strong>Email:</strong>
                            <%= contact.email %>
                        </p>
                        <p>
                            <%= contact.message %>
                        </p>
                    </article>
                    <% }) %>
            </div>
        </section>
    </section><%- include('partials/footer') %>