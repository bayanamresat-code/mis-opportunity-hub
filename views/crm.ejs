<%- include('partials/header', { currentPage, currentUser }) %>
  <div class="container">
    <div class="section-head">
      <div>
        <h1>CRM Workspace</h1>
        <p>Manage users, opportunities, contacts, and applications from one screen.</p>
      </div>
      <div class="toolbar"><a class="btn btn-primary" href="/manage/opportunity/new">Add Opportunity</a><a
          class="btn btn-secondary" href="/admin-dashboard">Back to dashboard</a></div>
    </div>
    <% if (errorMessage) { %>
      <div class="flash error">
        <%= errorMessage %>
      </div>
      <% } %>
        <div class="section-head">
          <div>
            <h2>Applications</h2>
            <p>Update notes and statuses directly from CRM.</p>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Opportunity</th>
                <th>Company</th>
                <th>Status</th>
                <th>Notes</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (!applications.length) { %>
                <tr>
                  <td colspan="7">No applications found.</td>
                </tr>
                <% } %>
                  <% applications.forEach(app=> { %>
                    <tr>
                      <td>
                        <%= app.fullname %>
                      </td>
                      <td>
                        <%= app.email %>
                      </td>
                      <td>
                        <%= app.title %>
                      </td>
                      <td>
                        <%= app.company_name || '—' %>
                      </td>
                      <td>
                        <form method="POST" action="/applications/<%= app.id %>/status" class="stack">
                          <select name="status">
                            <option value="pending" <%=app.status==='pending' ? 'selected' : '' %>>pending</option>
                            <option value="reviewed" <%=app.status==='reviewed' ? 'selected' : '' %>>reviewed</option>
                            <option value="accepted" <%=app.status==='accepted' ? 'selected' : '' %>>accepted</option>
                            <option value="rejected" <%=app.status==='rejected' ? 'selected' : '' %>>rejected</option>
                          </select>
                      </td>
                      <td><textarea name="notes"><%= app.notes || '' %></textarea></td>
                      <td><button class="btn btn-primary">Save</button></form>
                      </td>
                    </tr>
                    <% }) %>
            </tbody>
          </table>
        </div>
        <div class="section-head" style="margin-top:24px;">
          <div>
            <h2>Opportunities</h2>
            <p>Edit active jobs, internships, and projects with contact info.</p>
          </div>
        </div>
        <div class="list-grid">
          <% opportunities.forEach(item=> { %>
            <article class="card stack">
              <span class="badge">
                <%= item.category %>
              </span>
              <h3>
                <%= item.title %>
              </h3>
              <p><strong>Company:</strong>
                <%= item.company_name || '—' %>
              </p>
              <p><strong>Contact:</strong>
                <%= item.contact_name || '—' %>
              </p>
              <p><strong>Status:</strong>
                <%= item.status %>
              </p>
              <div class="toolbar">
                <a class="btn btn-secondary" href="/manage/opportunity/<%= item.id %>/edit">Edit</a>
                <form method="POST" action="/manage/opportunity/<%= item.id %>/delete"
                  onsubmit="return confirm('Delete this opportunity?')">
                  <button class="btn btn-danger">Delete</button>
                </form>
              </div>
            </article>
            <% }) %>
        </div>
        <div class="grid-3" style="margin-top:24px;">
          <section class="card">
            <h3>Users</h3>
            <% users.forEach(user=> { %><p><strong>
                  <%= user.fullname %>
                </strong><br><span class="muted">
                  <%= user.email %> · <%= user.role %>
                </span></p>
              <% }) %>
          </section>
          <section class="card">
            <h3>Contacts</h3>
            <% contacts.forEach(contact=> { %><p><strong>
                  <%= contact.subject %>
                </strong><br><span class="muted">
                  <%= contact.name %> · <%= contact.email %>
                </span></p>
              <% }) %>
          </section>
          <section class="card">
            <h3>CRM notes</h3>
            <p>Use the admin dashboard for KPI overview and this page for operational updates, pipeline reviews, and
              opportunity maintenance.</p>
          </section>
        </div>
  </div>
  <%- include('partials/footer') %>