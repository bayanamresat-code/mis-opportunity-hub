<%- include('partials/header', { currentPage }) %>

  <section class="crm-page">
    <div class="jobs-header">
      <h2>CRM Dashboard</h2>
      <p>A clean workspace for managing users, opportunities, contacts, and platform activity in one place.</p>
    </div>

    <!-- Top stats -->
    <section class="stats-grid">
      <div class="stat-card">
        <h3>
          <%= users ? users.length : 0 %>
        </h3>
        <p>Total users</p>
      </div>
      <div class="stat-card">
        <h3>
          <%= opportunities ? opportunities.length : 0 %>
        </h3>
        <p>Total opportunities</p>
      </div>
      <div class="stat-card">
        <h3>
          <%= contacts ? contacts.length : 0 %>
        </h3>
        <p>Contact requests</p>
      </div>
      <div class="stat-card">
        <h3>
          <%= users ? users.filter(u=> u.role === 'employer').length : 0 %>
        </h3>
        <p>Employers</p>
      </div>
    </section>

    <!-- Charts -->
    <section class="about">
      <div class="section-toolbar">
        <div>
          <h3>Statistics</h3>
          <p>Monitor platform activity through visual summaries and distribution charts.</p>
        </div>
      </div>

      <div class="charts-grid">
        <div class="chart-card">
          <h4>Opportunities by Category</h4>
          <canvas id="opportunitiesCategoryChart"></canvas>
        </div>

        <div class="chart-card">
          <h4>Opportunities by Status</h4>
          <canvas id="opportunitiesStatusChart"></canvas>
        </div>

        <div class="chart-card">
          <h4>Users by Role</h4>
          <canvas id="usersRoleChart"></canvas>
        </div>

        <div class="chart-card">
          <h4>Contacts Overview</h4>
          <canvas id="contactsChart"></canvas>
        </div>
      </div>
    </section>

    <!-- Users table -->
    <section class="about">
      <div class="section-toolbar">
        <div>
          <h3>Users</h3>
          <p>Manage registered accounts and review user roles.</p>
        </div>
        <span class="section-count">
          <%= users ? users.length : 0 %> records
        </span>
      </div>

      <% if (!users || users.length===0) { %>
        <p>No users available.</p>
        <% } else { %>
          <div class="table-tools">
            <input type="text" class="table-search" data-table-search="users-table" placeholder="Search users...">
          </div>

          <div class="crm-table-wrapper">
            <table class="crm-table" id="users-table">
              <thead>
                <tr>
                  <th>Full name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(user=> { %>
                  <tr>
                    <td><span class="cell-title">
                        <%= user.fullname %>
                      </span></td>
                    <td>
                      <%= user.email %>
                    </td>
                    <td><span class="badge badge-<%= user.role %>">
                        <%= user.role %>
                      </span></td>
                    <td>
                      <%= user.created_at || 'N/A' %>
                    </td>
                    <td>
                      <div class="table-actions">
                        <button type="button" class="action-btn edit">Edit</button>

                        <form class="inline-form" action="/delete-user/<%= user.id %>" method="POST"
                          onsubmit="return confirm('Delete user <%= user.fullname %>?')">
                          <button type="submit" class="action-btn delete">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
    </section>

    <!-- Opportunities table -->
    <section class="about">
      <div class="section-toolbar">
        <div>
          <h3>Opportunities</h3>
          <p>Track jobs, internships, and projects published on the platform.</p>
        </div>
        <span class="section-count">
          <%= opportunities ? opportunities.length : 0 %> records
        </span>
      </div>

      <% if (!opportunities || opportunities.length===0) { %>
        <p>No opportunities available.</p>
        <% } else { %>
          <div class="table-tools">
            <input type="text" class="table-search" data-table-search="opportunities-table"
              placeholder="Search opportunities...">
          </div>

          <div class="crm-table-wrapper">
            <table class="crm-table" id="opportunities-table">
              <thead>
                <tr>
                  <th>Title</th>
                  <th>Company</th>
                  <th>Contact Name</th>
                  <th>Contact Email</th>
                  <th>Contact Phone</th>
                  <th>Location</th>
                  <th>Category</th>
                  <th>Status</th>
                  <th>Description</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% opportunities.forEach(item=> { %>
                  <tr>
                    <td><span class="cell-title">
                        <%= item.title %>
                      </span></td>
                    <td>
                      <%= item.company || 'N/A' %>
                    </td>
                    <td>
                      <%= item.contact_name || 'N/A' %>
                    </td>
                    <td>
                      <% if (item.contact_email) { %>
                        <a href="mailto:<%= item.contact_email %>">
                          <%= item.contact_email %>
                        </a>
                        <% } else { %>
                          N/A
                          <% } %>
                    </td>
                    <td>
                      <%= item.contact_phone || 'N/A' %>
                    </td>
                    <td>
                      <%= item.location %>
                    </td>
                    <td><span class="badge badge-<%= item.category %>">
                        <%= item.category %>
                      </span></td>
                    <td><span class="badge badge-<%= item.status || 'open' %>">
                        <%= item.status || 'open' %>
                      </span></td>
                    <td>
                      <%= item.description %>
                    </td>
                    <td>
                      <%= item.created_at || 'N/A' %>
                    </td>
                    <td>
                      <div class="table-actions">
                        <a href="/edit-opportunity/<%= item.id %>" class="action-btn edit">Edit</a>

                        <form class="inline-form" action="/delete-opportunity/<%= item.id %>" method="POST"
                          onsubmit="return confirm('Delete opportunity <%= item.title %>?')">
                          <button type="submit" class="action-btn delete">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
    </section>

    <!-- Contacts table -->
    <section class="about">
      <div class="section-toolbar">
        <div>
          <h3>Contacts</h3>
          <p>Review inbound messages and follow up with senders.</p>
        </div>
        <span class="section-count">
          <%= contacts ? contacts.length : 0 %> records
        </span>
      </div>

      <% if (!contacts || contacts.length===0) { %>
        <p>No contact messages available.</p>
        <% } else { %>
          <div class="table-tools">
            <input type="text" class="table-search" data-table-search="contacts-table" placeholder="Search contacts...">
          </div>

          <div class="crm-table-wrapper">
            <table class="crm-table" id="contacts-table">
              <thead>
                <tr>
                  <th>Subject</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Message</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% contacts.forEach(contact=> { %>
                  <tr>
                    <td><span class="cell-title">
                        <%= contact.subject %>
                      </span></td>
                    <td>
                      <%= contact.name %>
                    </td>
                    <td><a href="mailto:<%= contact.email %>">
                        <%= contact.email %>
                      </a></td>
                    <td>
                      <%= contact.message %>
                    </td>
                    <td>
                      <%= contact.created_at || 'N/A' %>
                    </td>
                    <td>
                      <div class="table-actions">
                        <button type="button" class="action-btn edit">View</button>

                        <form class="inline-form" action="/delete-contact/<%= contact.id %>" method="POST"
                          onsubmit="return confirm('Delete this contact message from <%= contact.name %>?')">
                          <button type="submit" class="action-btn delete">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
    </section>
  </section>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0"></script>

<script
  id="crm-data"
  type="application/json"
>
  <%- JSON.stringify({ users, opportunities, contacts }) %>
</script>

<script>
  const raw = document.getElementById('crm-data').textContent;
  const parsed = JSON.parse(raw || '{}');

  const usersData = parsed.users || [];
  const opportunitiesData = parsed.opportunities || [];
  const contactsData = parsed.contacts || [];
</script>

    function countBy(items, key, fallback = 'Unknown') {
      return items.reduce((acc, item) => {
        const value = item[key] || fallback;
        acc[value] = (acc[value] || 0) + 1;
        return acc;
      }, {});
    }

    const roleCounts = countBy(usersData, 'role');
    const categoryCounts = countBy(opportunitiesData, 'category');
    const statusCounts = countBy(opportunitiesData, 'status', 'open');

    const contactsOverview = {
      labels: ['Messages received'],
      values: [contactsData.length]
    };

    // Charts
    new Chart(document.getElementById('opportunitiesCategoryChart'), {
      type: 'doughnut',
      data: {
        labels: Object.keys(categoryCounts),
        datasets: [{
          data: Object.values(categoryCounts),
          backgroundColor: ['#0d6efd', '#20c997', '#ffc107', '#dc3545', '#6f42c1']
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'top' }
        }
      }
    });

    new Chart(document.getElementById('opportunitiesStatusChart'), {
      type: 'bar',
      data: {
        labels: Object.keys(statusCounts),
        datasets: [{
          label: 'Count',
          data: Object.values(statusCounts),
          backgroundColor: ['#198754', '#dc3545', '#fd7e14', '#0dcaf0']
        }]
      },
      options: {
        responsive: true,
        scales: {
          y: {
            beginAtZero: true,
            ticks: { precision: 0 }
          }
        }
      }
    });

    new Chart(document.getElementById('usersRoleChart'), {
      type: 'pie',
      data: {
        labels: Object.keys(roleCounts),
        datasets: [{
          data: Object.values(roleCounts),
          backgroundColor: ['#0d6efd', '#6610f2', '#20c997', '#ffc107', '#dc3545']
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'top' }
        }
      }
    });

    new Chart(document.getElementById('contactsChart'), {
      type: 'bar',
      data: {
        labels: contactsOverview.labels,
        datasets: [{
          label: 'Contacts',
          data: contactsOverview.values,
          backgroundColor: ['#6c757d']
        }]
      },
      options: {
        responsive: true,
        scales: {
          y: {
            beginAtZero: true,
            ticks: { precision: 0 }
          }
        }
      }
    });
  </script>

  <%- include('partials/footer') %>