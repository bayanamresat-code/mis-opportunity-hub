<%- include('partials/header') %>
    <section>
        <div class="section-head">
            <h1>Graduate Dashboard</h1>
            <p>Welcome, <%= user.fullname %>.</p>
        </div>
        <div class="stats-grid">
            <div class="stat-card"><span>Applications</span><strong>
                    <%= apps.length %>
                </strong></div>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    <% apps.forEach(app=> { %><tr>
                            <td>
                                <%= app.title %>
                            </td>
                            <td>
                                <%= app.category %>
                            </td>
                            <td>
                                <%= app.status %>
                            </td>
                            <td>
                                <%= app.notes || '' %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </section><%- include('partials/footer') %>