<%- include('partials/header', { currentPage }) %>

<section class="jobs-page">
  <div class="jobs-header about">
    <h2>Graduate Dashboard</h2>
    <p>Welcome, <%= user.fullname %>. Manage your career opportunities from one place.</p>
  </div>

  <div class="cards-container">
    <div class="card">
      <h3>Your Role</h3>
      <p><strong>Graduate</strong></p>
