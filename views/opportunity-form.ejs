<%- include('partials/header', { currentPage, currentUser }) %>
    <div class="container" style="max-width: 960px;">
        <div class="section-head">
            <div>
                <h1>
                    <%= pageTitle %>
                </h1>
                <p>Create or edit a card with full recruiter contact information.</p>
            </div>
        </div>
        <section class="panel">
            <form method="POST" action="<%= action %>" class="stack">
                <div class="form-grid">
                    <div><label>Title</label><input name="title" value="<%= item ? item.title : '' %>" required /></div>
                    <div><label>Company</label><input name="company_name"
                            value="<%= item ? item.company_name || '' : '' %>" /></div>
                </div>
                <div class="form-grid">
                    <div><label>Contact name</label><input name="contact_name"
                            value="<%= item ? item.contact_name || '' : '' %>" /></div>
                    <div><label>Contact email</label><input type="email" name="contact_email"
                            value="<%= item ? item.contact_email || '' : '' %>" /></div>
                </div>
                <div class="form-grid">
                    <div><label>Contact phone</label><input name="contact_phone"
                            value="<%= item ? item.contact_phone || '' : '' %>" /></div>
                    <div><label>Location</label><input name="location" value="<%= item ? item.location : '' %>"
                            required /></div>
                </div>
                <div class="form-grid">
                    <div><label>Category</label>
                        <select name="category" required>
                            <option value="job" <%=item && item.category==='job' ? 'selected' : '' %>>Job</option>
                            <option value="internship" <%=item && item.category==='internship' ? 'selected' : '' %>
                                >Internship</option>
                            <option value="project" <%=item && item.category==='project' ? 'selected' : '' %>>Project
                            </option>
                        </select>
                    </div>
                    <div><label>Status</label>
                        <select name="status">
                            <option value="open" <%=!item || item.status==='open' ? 'selected' : '' %>>Open</option>
                            <option value="closed" <%=item && item.status==='closed' ? 'selected' : '' %>>Closed
                            </option>
                            <option value="draft" <%=item && item.status==='draft' ? 'selected' : '' %>>Draft</option>
                        </select>
                    </div>
                </div>
                <div><label>Description</label><textarea
                        name="description"><%= item ? item.description || '' : '' %></textarea></div>
                <div class="toolbar"><button class="btn btn-primary">Save opportunity</button><a
                        class="btn btn-secondary" href="/crm">Cancel</a></div>
            </form>
        </section>
    </div>
    <%- include('partials/footer') %>