<%- include('partials/header', { currentPage, currentUser }) %>
<div class="container" style="max-width: 860px;">
  <div class="section-head"><div><h1>Create account</h1><p>Open a new student, graduate, or employer account.</p></div></div>
  <% if (flash) { %><div class="flash <%= flash.type %>"><%= flash.text %></div><% } %>
  <section class="panel">
    <form method="POST" action="/signup" class="stack">
      <div class="form-grid">
        <div><label>Full name</label><input name="fullname" required /></div>
        <div><label>Email</label><input type="email" name="email" required /></div>
      </div>
      <div class="form-grid">
        <div><label>Password</label><input type="password" name="password" required /></div>
        <div><label>Role</label>
          <select name="role" required>
            <option value="student">Student</option>
            <option value="graduate">Graduate</option>
            <option value="employer">Employer</option>
          </select>
        </div>
      </div>
      <button class="btn btn-primary">Create account</button>
    </form>
  </section>
</div>
<%- include('partials/footer') %>