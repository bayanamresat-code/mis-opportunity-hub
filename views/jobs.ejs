<%- include('partials/header', { currentPage }) %>

<section class="jobs-page">
  <div class="jobs-header">
    <h2><%= title %></h2>
    <p><%= subtitle %></p>
  </div>

  <% if (!items || items.length === 0) { %>
    <p>No jobs available at the moment.</p>
  <% } else { %>
    <div class="cards-grid">
      <% items.forEach(item => { %>
        <article class="opportunity-card">

          <div class="card-header">
            <span class="job-badge"><%= item.category || 'Job' %></span>
            <span class="status-badge"><%= item.status || 'Open' %></span>
          </div>

          <h3 class="job-title"><%= item.title %></h3>

          <p class="company-name"><%= item.company || 'Company not specified' %></p>

          <div class="job-meta">
            <span>📍 <%= item.location || 'Location not specified' %></span>
          </div>

          <p class="job-description">
            <%= item.description || 'No description available.' %>
          </p>

          <div class="skills-tags">
            <span class="skill-tag">SQL</span>
            <span class="skill-tag">ERP</span>
            <span class="skill-tag">CRM</span>
            <span class="skill-tag">BI</span>
          </div>

          <div class="contact-section">
            <p><strong>Contact:</strong> <%= item.contact_name || 'N/A' %></p>

            <% if (item.contact_email) { %>
              <a href="mailto:<%= item.contact_email %>" class="contact-link">
                ✉ <%= item.contact_email %>
              </a>
            <% } %>

            <% if (item.contact_phone) { %>
              <p>📞 <%= item.contact_phone %></p>
            <% } %>
          </div>

          <div class="card-actions">
            <% if (item.source === 'AllJobs' && item.external_job_id) { %>
              <a href="https://www.alljobs.co.il/SearchResults.aspx/Single/<%= item.external_job_id %>" class="btn apply-btn" target="_blank">
                Apply Now
                <span style="font-size:0.75em; opacity:0.85;"> · AllJobs</span>
              </a>

            <% } else if (item.source === 'Drushim' && item.external_job_id) { %>
              <a href="https://www.drushim.co.il/job/cat2/<%= item.external_job_id %>/" class="btn apply-btn" target="_blank">
                Apply Now
                <span style="font-size:0.75em; opacity:0.85;"> · דרושים</span>
              </a>

            <% } else if (item.source === 'LinkedIn' && item.external_job_id) { %>
              <a href="https://www.linkedin.com/jobs/view/<%= item.external_job_id %>" class="btn apply-btn" target="_blank">
                Apply Now
                <span style="font-size:0.75em; opacity:0.85;"> · LinkedIn</span>
              </a>

            <% } else if (item.contact_email) { %>
              <a href="mailto:<%= item.contact_email %>" class="btn apply-btn" target="_blank">Apply Now</a>

            <% } else { %>
              <a href="https://www.google.com/search?q=<%= encodeURIComponent(item.company || item.title) %>" class="btn apply-btn" target="_blank">Apply Now</a>
            <% } %>
          </div>

        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>


