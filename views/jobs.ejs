<%- include('partials/header') %>
    <section>
        <div class="section-head">
            <h1>
                <%= title %>
            </h1>
            <p>
                <%= subtitle %>
            </p>
        </div>
        <div class="card-grid">
            <% items.forEach(item=> { %><article class="card"><span class="badge">
                        <%= item.status %>
                    </span>
                    <h3>
                        <%= item.title %>
                    </h3>
                    <p><strong>Location:</strong>
                        <%= item.location %>
                    </p>
                    <p>
                        <%= item.description %>
                    </p>
                    <% if (currentUser && ['student','graduate'].includes(currentUser.role)) { %>
                        <form method="POST" action="/apply/<%= item.id %>"><button class="btn-primary">Apply</button>
                        </form>
                        <% } %>
                </article>
                <% }) %>
        </div>
    </section><%- include('partials/footer') %>