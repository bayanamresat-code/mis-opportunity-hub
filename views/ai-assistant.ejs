<%- include('partials/header') %>
    <section class="ai-shell">
        <div class="section-head">
            <h1>AI Assistant</h1>
            <p>Ask for skills analysis, job guidance, CRM summaries, or message drafting.</p>
        </div>
        <div id="aiMessages" class="ai-messages">
            <div class="ai-bubble assistant">Hello <%= currentUser.fullname %>, ask me about opportunities, skills, or
                    CRM summaries.</div>
        </div>
        <form id="aiForm" class="ai-form"><textarea id="aiInput"
                placeholder="Example: Which skills are most common in north Israel analyst jobs?"
                rows="3"></textarea><button class="btn-primary">Send</button></form>
    </section><%- include('partials/footer') %>