<%- include('partials/header', { currentPage }) %>

<section class="form-page">
  <div class="form-box">
    <h2>Login</h2>
    <p>Access your account to continue.</p>
    <% if (message) { %>
  <div class="message-box <%= messageType || 'success' %>">
    <%= message %>
    </div>
    <% } %>
    
    <form id="login-form" data-validate="true" method="POST" action="/login">
      <input id="login-email" name="email" type="email" placeholder="Email address" required>
      <input id="login-password" name="password" type="password" placeholder="Password" required>
      <button type="submit">Login</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
