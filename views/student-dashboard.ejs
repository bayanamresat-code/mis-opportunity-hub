<%- include('partials/header', { currentPage }) %>

<section class="jobs-page">
  <div class="jobs-header about">
    <h2>Student Dashboard</h2>
    <p>Welcome, <%= user.fullname %>. Explore opportunities and track your progress.</p>
  </div>

  <div class="cards-container">
    <div class="card">
      <h3>Your Role</h3>
      <p><strong>Student</strong></p>
    </div>

    <div class="card">
      <h3>Available Opportunities</h3>
      <p>You can browse jobs, internships, and projects from the platform.</p>
      <a href="/jobs" class="btn">Browse Jobs</a>
    </div>

    <div class="card">
      <h3>Quick Access</h3>
      <p>Check internships and projects that fit your academic path.</p>
      <a href="/internships" class="btn">View Internships</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
