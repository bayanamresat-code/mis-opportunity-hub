<%- include('partials/header', { currentPage, currentUser }) %>
    <div class="container">
        <div class="section-head">
            <div>
                <h1>
                    <%= title %>
                </h1>
                <p>
                    <%= subtitle %>
                </p>
            </div>
        </div>
        <div class="list-grid">
            <% items.forEach(item=> { %>
                <article class="card stack">
                    <span class="badge">
                        <%= item.status %>
                    </span>
                    <h3>
                        <%= item.title %>
                    </h3>
                    <p><strong>Company:</strong>
                        <%= item.company_name || '—' %>
                    </p>
                    <p><strong>Contact:</strong>
                        <%= item.contact_name || '—' %>
                    </p>
                    <p><strong>Email:</strong>
                        <%= item.contact_email || '—' %>
                    </p>
                    <p><strong>Phone:</strong>
                        <%= item.contact_phone || '—' %>
                    </p>
                    <p><strong>Location:</strong>
                        <%= item.location %>
                    </p>
                    <p class="muted">
                        <%= item.description %>
                    </p>
                    <% if (currentUser && (currentUser.role==='student' || currentUser.role==='graduate' )) { %>
                        <form method="POST" action="/apply/<%= item.id %>"><button
                                class="btn btn-primary">Apply</button></form>
                        <% } %>
                </article>
                <% }) %>
        </div>
    </div>
    <%- include('partials/footer') %>