<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Opportunity Hub</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <nav class="navbar">
        <a href="/" class="logo">Opportunity Hub</a>

        <div class="nav-links">
          <a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>">Home</a>
          <a href="/jobs" class="<%= currentPage === 'jobs' ? 'active' : '' %>">Jobs</a>
          <a href="/internships" class="<%= currentPage === 'internships' ? 'active' : '' %>">Internships</a>
          <a href="/projects" class="<%= currentPage === 'projects' ? 'active' : '' %>">Projects</a>
          <a href="/contact" class="<%= currentPage === 'contact' ? 'active' : '' %>">Contact</a>

          <% if (!currentUser) { %>
            <a href="/login" class="<%= currentPage === 'login' ? 'active' : '' %>">Login</a>
            <a href="/signup" class="<%= currentPage === 'signup' ? 'active' : '' %>">Sign Up</a>
          <% } else { %>
            <% if (currentUser.role === 'student') { %>
              <a href="/student-dashboard">Dashboard</a>
            <% } %>

            <% if (currentUser.role === 'graduate') { %>
              <a href="/graduate-dashboard">Dashboard</a>
            <% } %>

            <% if (currentUser.role === 'employer') { %>
              <a href="/employer-dashboard">Dashboard</a>
              <a href="/crm">CRM</a>
            <% } %>

            <% if (currentUser.role === 'admin') { %>
              <a href="/admin-dashboard">Admin</a>
              <a href="/crm">CRM</a>
            <% } %>

            <a href="/logout">Logout</a>
          <% } %>
        </div>
      </nav>
    </div>
  </header>

  <main class="page-container">
    