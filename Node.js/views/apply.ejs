<%- include('partials/header', { currentPage }) %>

<section class="form-page">
  <div class="form-box">
    <h2>Apply for Opportunity</h2>

    <p class="mb-2">
      Please fill in your details and upload your CV.
    </p>

    <form action="/apply/<%= opportunity.id %>" method="POST" enctype="multipart/form-data">
      <label for="full_name">Full Name</label>
      <input
        type="text"
        id="full_name"
        name="full_name"
        value="<%= user.fullname %>"
        required
      >

      <label for="email">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        value="<%= user.email %>"
        required
      >

      <label for="phone">Phone</label>
      <input
        type="text"
        id="phone"
        name="phone"
        placeholder="Enter your phone number"
      >

      <label for="cv">Upload CV</label>
      <input
        type="file"
        id="cv"
        name="cv"
        accept=".pdf,.doc,.docx"
        required
      >

      <label for="notes">Notes</label>
      <textarea
        id="notes"
        name="notes"
        rows="5"
        placeholder="Write a short message to the employer..."
      ></textarea>

      <button type="submit" class="btn">
        Submit Application
      </button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>

