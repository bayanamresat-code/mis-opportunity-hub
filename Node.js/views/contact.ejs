<%- include('partials/header', { currentPage }) %>

<section class="contact-page">
  <div class="contact-hero">
    <div>
      <span class="eyebrow">Contact Us</span>
      <h1>Contact Opportunity Hub</h1>
      <p>
        Have a question, suggestion, or partnership idea? Send us a message and we will get back to you as soon as possible.
      </p>
    </div>

    <a href="/signup" class="btn">Join the Platform</a>
  </div>

  <div class="contact-layout">
    <section class="contact-form-card">
      <h2>Get in Touch</h2>
      <p>Use the form below for questions, feedback, employer collaboration, or technical support.</p>

      <% if (message) { %>
        <div class="message-box <%= messageType || 'success' %>">
          <%= message %>
        </div>
      <% } %>

      <form method="POST" action="/contact" class="contact-form">
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" placeholder="Enter your full name" required>
        </div>

        <div class="form-group">
          <label>Email Address</label>
          <input type="email" name="email" placeholder="Enter your email address" required>
        </div>

        <div class="form-group">
          <label>Subject</label>
          <input type="text" name="subject" placeholder="What is your message about?" required>
        </div>

        <div class="form-group">
          <label>Message</label>
          <textarea name="message" placeholder="Write your message here..." required></textarea>
        </div>

        <button type="submit" class="btn contact-submit-btn">
          Send Message
        </button>
      </form>
    </section>

    <aside class="contact-info-card">
      <h2>Who Can Contact Us?</h2>
      <p>
        Opportunity Hub supports students, graduates, employers, and administrators in one shared platform.
      </p>

      <div class="contact-info-list">
        <div class="contact-info-item">
          <span>🎓</span>
          <div>
            <h3>Students</h3>
            <p>Ask about internships, projects, and how to get started.</p>
          </div>
        </div>

        <div class="contact-info-item">
          <span>💼</span>
          <div>
            <h3>Graduates</h3>
            <p>Contact us about jobs, career growth, and professional opportunities.</p>
          </div>
        </div>

        <div class="contact-info-item">
          <span>🏢</span>
          <div>
            <h3>Employers</h3>
            <p>Publish opportunities, collaborate, and reach suitable candidates.</p>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>

<%- include('partials/footer') %>
