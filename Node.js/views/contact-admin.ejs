<%- include('partials/header', { currentPage }) %>

<section class="dashboard-page">
  <div class="dashboard-hero">
    <h2>Contact Admin</h2>
    <p>
      Send a professional request to <%= admin.fullname %>. Use this form for support,
      opportunity coordination, or meeting requests.
    </p>
  </div>

  <div class="request-flow-note">
    <div class="request-step">
      <strong>1. Employer submits</strong>
      <span>The employer sends a request to the admin with contact preferences.</span>
    </div>
    <div class="request-step">
      <strong>2. Admin reviews</strong>
      <span>The request appears in the admin panel with a visible status.</span>
    </div>
    <div class="request-step">
      <strong>3. Follow-up starts</strong>
      <span>The admin updates progress and can schedule a meeting if needed.</span>
    </div>
  </div>

  <% if (message) { %>
    <div class="alert <%= messageType %>">
      <%= message %>
    </div>
  <% } %>

  <div class="dashboard-card contact-request-card">
    <form action="/employer/contact-admin" method="POST" class="contact-request-form">
      <div class="form-group">
        <label for="subject">Subject</label>
        <input
          type="text"
          id="subject"
          name="subject"
          value="<%= formData?.subject || '' %>"
          placeholder="Example: Request to schedule employer-admin meeting"
          required
        >
      </div>

      <div class="form-group">
        <label for="message">Message</label>
        <textarea
          id="message"
          name="message"
          rows="6"
          placeholder="Describe your request clearly and include the purpose of the contact."
          required
        ><%= formData?.message || '' %></textarea>
      </div>

      <div class="form-group">
        <label for="preferred_channel">Preferred Contact Method</label>
        <select id="preferred_channel" name="preferred_channel" required>
          <option value="email" <%= formData?.preferred_channel === 'email' ? 'selected' : '' %>>Email</option>
          <option value="whatsapp" <%= formData?.preferred_channel === 'whatsapp' ? 'selected' : '' %>>WhatsApp</option>
          <option value="meeting" <%= formData?.preferred_channel === 'meeting' ? 'selected' : '' %>>Google Calendar Meeting</option>
        </select>
      </div>

      <div
        class="form-group"
        id="whatsapp-phone-group"
        <%= formData?.preferred_channel !== 'whatsapp' ? 'style="display: none;"' : '' %>
      >
        <label for="contact_phone">Phone Number for WhatsApp</label>
        <input
          type="tel"
          id="contact_phone"
          name="contact_phone"
          value="<%= formData?.contact_phone || '' %>"
          placeholder="Example: 0501234567"
          pattern="^[0-9+\-\s()]{9,20}$"
        >
        <small>Required only if WhatsApp is selected.</small>
      </div>

      <div class="checkbox-row">
        <input
          type="checkbox"
          id="meeting_requested"
          name="meeting_requested"
          <%= formData?.meeting_requested ? 'checked' : '' %>
        >
        <label for="meeting_requested">I want to schedule a meeting</label>
      </div>

      <button type="submit" class="btn">Send Request</button>
    </form>
  </div>

  <div class="dashboard-card contact-request-card mt-3">
    <div class="section-toolbar">
      <div>
        <h3>Employer Requests</h3>
        <p>Track every request you sent to the admin, including status and follow-up details.</p>
      </div>
      <span class="section-count">
        <%= contactRequests?.length || 0 %> request(s)
      </span>
    </div>

    <% if (contactRequests && contactRequests.length > 0) { %>
      <div class="requests-table-wrapper">
        <table class="requests-table">
          <thead>
            <tr>
              <th>Subject</th>
              <th>Preferred Contact</th>
              <th>Status</th>
              <th>Meeting</th>
              <th>Sent At</th>
            </tr>
          </thead>
          <tbody>
            <% contactRequests.forEach((request) => { %>
              <tr>
                <td>
                  <div class="contact-meta">
                    <span class="meta-title"><%= request.subject %></span>
                    <span class="meta-subtext">Request ID: <%= request.id %></span>
                  </div>
                </td>

                <td>
                  <div class="contact-meta">
                    <span class="meta-title"><%= request.preferred_channel || 'email' %></span>

                    <% if (request.preferred_channel === 'whatsapp' && request.phone) { %>
                      <a
                        class="meta-subtext contact-link"
                        href="tel:<%= String(request.phone).replace(/[^0-9+]/g, '') %>"
                      >
                        <%= request.phone %>
                      </a>
                    <% } %>

                    <% if (request.preferred_channel === 'meeting') { %>
                      <span class="meta-subtext">Calendar follow-up preferred</span>
                    <% } %>
                  </div>
                </td>

                <td>
                  <span class="status-badge status-<%= request.status %>">
                    <%= request.status === 'in_progress'
                      ? 'In Progress'
                      : request.status === 'done'
                      ? 'Done'
                      : 'New' %>
                  </span>
                </td>

                <td><%= request.meeting_requested ? 'Yes' : 'No' %></td>

                <td>
                  <div class="contact-meta">
                    <span class="meta-title">
                      <%= new Date(request.created_at).toLocaleDateString() %>
                    </span>
                    <span class="meta-subtext">
                      <%= new Date(request.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                    </span>
                  </div>
                </td>
              </tr>

              <tr class="request-message-row">
                <td colspan="5">
                  <div class="request-message-box">
                    <strong>Your message:</strong>
                    <div><%= request.message %></div>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state-box">
        You have not sent any requests yet.
      </div>
    <% } %>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const preferredChannel = document.getElementById('preferred_channel');
    const whatsappPhoneGroup = document.getElementById('whatsapp-phone-group');
    const phoneInput = document.getElementById('contact_phone');

    function toggleWhatsappPhoneField() {
      const isWhatsapp = preferredChannel.value === 'whatsapp';
      whatsappPhoneGroup.style.display = isWhatsapp ? 'block' : 'none';
      phoneInput.required = isWhatsapp;

      if (!isWhatsapp) {
        phoneInput.value = '';
      }
    }

    toggleWhatsappPhoneField();
    preferredChannel.addEventListener('change', toggleWhatsappPhoneField);
  });
</script>

<%- include('partials/footer') %>