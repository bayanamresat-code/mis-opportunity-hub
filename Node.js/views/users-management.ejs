<%- include('partials/header', { currentPage }) %>

<section class="crm-page">
  <div class="jobs-header">
    <h2>User Management</h2>
    <p>Manage all registered users across the platform.</p>
  </div>

<section class="stats-grid admin-stats users-stats">
  <div class="stat-card admin-stat-card users-stat-card">
    <div class="stat-icon">👥</div>
    <div>
      <h3><%= users ? users.length : 0 %></h3>
      <p>Total Users</p>
    </div>
  </div>

  <div class="stat-card admin-stat-card users-stat-card">
    <div class="stat-icon">🛡️</div>
    <div>
      <h3><%= users ? users.filter(u => u.role === 'admin').length : 0 %></h3>
      <p>Admins</p>
    </div>
  </div>

  <div class="stat-card admin-stat-card users-stat-card">
    <div class="stat-icon">🎓</div>
    <div>
      <h3><%= users ? users.filter(u => u.role === 'student').length : 0 %></h3>
      <p>Students</p>
    </div>
  </div>

  <div class="stat-card admin-stat-card users-stat-card">
    <div class="stat-icon">🏢</div>
    <div>
      <h3><%= users ? users.filter(u => u.role === 'employer').length : 0 %></h3>
      <p>Employers</p>
    </div>
  </div>

  <div class="stat-card admin-stat-card users-stat-card">
  <div class="stat-icon">🎯</div>
  <div>
    <h3><%= users ? users.filter(u => u.role === 'graduate').length : 0 %></h3>
    <p>Graduates</p>
  </div>
</div>

</section>


  <section class="about">
    <div class="section-toolbar">
      <div>
        <h3>Users</h3>
        <p>Manage registered accounts and review user roles.</p>
      </div>
      <span class="section-count">
        <%= users ? users.length : 0 %> records
      </span>
    </div>

    <% if (!users || users.length === 0) { %>
      <p>No users available.</p>
    <% } else { %>
      <div class="table-tools">
        <input type="text" class="table-search" data-table-search="users-table" placeholder="Search users...">
      </div>

      <div class="crm-table-wrapper">
        <table class="crm-table" id="users-table">
          <thead>
            <tr>
              <th>Full name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td>
                  <span class="cell-title"><%= user.fullname %></span>
                </td>

                <td><%= user.email %></td>

                <td>
                  <span class="badge badge-<%= user.role %>">
                    <%= user.role %>
                  </span>
                </td>

                <td>
                  <span class="badge badge-open">Active</span>
                </td>

                <td><%= user.created_at || 'N/A' %></td>

                <td>
                  <div class="table-actions">
                    <a href="/edit-user/<%= user.id %>" class="action-btn edit">Edit</a>

                    <form class="inline-form" action="/delete-user/<%= user.id %>" method="POST"
                      onsubmit="return confirm('Delete user <%= user.fullname %>?')">
                      <button type="submit" class="action-btn delete">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</section>

<script>
  document.querySelectorAll('[data-table-search]').forEach(input => {
    input.addEventListener('input', function () {
      const tableId = this.getAttribute('data-table-search');
      const table = document.getElementById(tableId);
      if (!table) return;

      const rows = table.querySelectorAll('tbody tr');
      const value = this.value.toLowerCase().trim();

      rows.forEach(row => {
        const text = row.innerText.toLowerCase();
        row.style.display = text.includes(value) ? '' : 'none';
      });
    });
  });
</script>

<%- include('partials/footer') %>
