<%- include('partials/header', { currentPage }) %>

<section class="dashboard-page">
  <div class="dashboard-hero">
    <h2>💼 My Jobs</h2>
    <p>View and manage job opportunities published by your company.</p>
  </div>

  <div class="dashboard-card">
    <% if (!jobs || jobs.length === 0) { %>
      <p>No jobs found yet.</p>
    <% } else { %>
      <table class="dashboard-table">
        <thead>
          <tr>
            <th>Job Title</th>
            <th>Location</th>
            <th>Status</th>
            <th>Created At</th>
          </tr>
        </thead>
        <tbody>
          <% jobs.forEach(job => { %>
            <tr>
              <td><%= job.title %></td>
              <td><%= job.location %></td>
              <td><%= job.status %></td>
              <td><%= new Date(job.created_at).toLocaleDateString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>