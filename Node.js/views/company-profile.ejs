<%- include('partials/header', { currentPage }) %>

  <section class="crm-page">
    <div class="dashboard-hero">
      <h2>🏢 Company Profile</h2>
      <p>Manage company information, contact details, and hiring preferences.</p>
    </div>

    <div class="dashboard-card">
      <div class="section-toolbar">
        <div>
          <h3>Company Information</h3>
          <p>Review your current company details and update them when needed.</p>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <p>Company Name</p>
          <h3 style="font-size:1.25rem;">
            <%= user?.fullname || 'Sample Company' %>
          </h3>
        </div>

        <div class="stat-card">
          <p>Contact Email</p>
          <h3 style="font-size:1.1rem;">
            <%= user?.email || 'employer123@gmail.com' %>
          </h3>
        </div>

        <div class="stat-card">
          <p>Industry</p>
          <h3 style="font-size:1.1rem;">Information Systems / Technology</h3>
        </div>
      </div>

      <div class="dashboard-card mt-2" style="box-shadow:none;">
        <div class="contact-meta">
          <span class="meta-title">Hiring Interests</span>
          <span class="meta-subtext">Students, Graduates, Internships, Projects</span>
        </div>

        <div class="table-actions mt-2">
          <a href="/edit-company-profile" class="action-btn edit">Edit Company Profile</a>
          <a href="/hiring-preferences" class="action-btn">Manage Hiring Preferences</a>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>