<%- include('partials/header', { currentPage }) %>

<section class="jobs-page">
  <div class="jobs-header about">
    <h2>📄 My Applications</h2>
    <p>Track the jobs, internships, and projects you applied for.</p>
  </div>

  <div class="crm-table-wrapper">
    <table class="crm-table">
      <thead>
        <tr>
          <th>Opportunity</th>
          <th>Company</th>
          <th>Type</th>
          <th>Status</th>
          <th>Applied Date</th>
          <th>CV</th>
        </tr>
      </thead>

      <tbody>
        <% if (!applications || applications.length === 0) { %>
          <tr>
            <td colspan="6">You have not applied to any opportunities yet.</td>
          </tr>
        <% } else { %>
          <% applications.forEach(app => { %>
            <tr>
              <td class="cell-title"><%= app.opportunity_title %></td>
              <td><%= app.company || 'N/A' %></td>
              <td>
                <span class="badge badge-<%= app.category %>">
                  <%= app.category %>
                </span>
              </td>
              <td>
                <span class="badge badge-job">
                  <%= app.status %>
                </span>
              </td>
              <td>
                <%= new Date(app.created_at).toISOString().slice(0, 10) %>
              </td>
              <td>
                <% if (app.cv_path) { %>
                  <a href="<%= app.cv_path %>" target="_blank">View CV</a>
                <% } else { %>
                  No CV
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
