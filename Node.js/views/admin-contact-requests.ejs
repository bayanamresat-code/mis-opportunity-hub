<%- include('partials/header', { currentPage }) %>

<section class="crm-page">
  <div class="dashboard-hero">
    <h2>Employer Contact Requests</h2>
    <p>
      Review employer messages, track request status, and update follow-up progress.
    </p>
  </div>

  <% if (message) { %>
    <div class="alert <%= messageType %>">
      <%= message %>
    </div>
  <% } %>

  <div class="dashboard-card contact-request-card">
    <div class="section-toolbar">
      <div>
        <h3>Requests Inbox</h3>
        <p>Manage incoming employer requests and update their progress.</p>
      </div>
      <span class="section-count">
        <%= requests?.length || 0 %> request(s)
      </span>
    </div>

    <% if (requests && requests.length > 0) { %>
      <div class="requests-table-wrapper">
        <table class="requests-table">
          <thead>
            <tr>
              <th>Employer</th>
              <th>Subject</th>
              <th>Channel</th>
              <th>Phone</th>
              <th>Meeting</th>
              <th>Status</th>
              <th>Date</th>
              <th>Action</th>
            </tr>
          </thead>

          <tbody>
            <% requests.forEach((reqItem) => { %>
              <tr>
                <td>
                  <div class="contact-meta">
                    <span class="meta-title">
                      <%= reqItem.employer_name || 'Employer' %>
                    </span>
                    <% if (reqItem.employer_email) { %>
                      <a class="meta-subtext contact-link" href="mailto:<%= reqItem.employer_email %>">
                        <%= reqItem.employer_email %>
                      </a>
                    <% } %>
                  </div>
                </td>

                <td>
                  <div class="contact-meta">
                    <span class="meta-title">
                      <%= reqItem.subject %>
                    </span>
                    <span class="meta-subtext">Request ID: <%= reqItem.id %></span>
                  </div>
                </td>

                <td>
                  <div class="contact-meta">
                    <span class="meta-title">
                      <%= reqItem.preferred_channel === 'meeting'
                        ? 'Google Calendar Meeting'
                        : reqItem.preferred_channel === 'whatsapp'
                        ? 'WhatsApp'
                        : 'Email' %>
                    </span>
                    <span class="meta-subtext">
                      Preferred contact method
                    </span>
                  </div>
                </td>

                <td><%= reqItem.phone || '-' %></td>

                <td>
                  <%= reqItem.meeting_requested ? 'Yes' : 'No' %>
                </td>

                <td>
                  <span class="status-badge status-<%= reqItem.status %>">
                    <%= reqItem.status === 'new'
                      ? 'New'
                      : reqItem.status === 'in_progress'
                      ? 'In Progress'
                      : 'Done' %>
                  </span>
                </td>

                <td>
                  <div class="contact-meta">
                    <span class="meta-title">
                      <%= new Date(reqItem.created_at).toLocaleDateString() %>
                    </span>
                    <span class="meta-subtext">
                      <%= new Date(reqItem.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                    </span>
                  </div>
                </td>

                <td>
                  <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <a href="/admin/contact-requests/<%= reqItem.id %>" class="btn">Open</a>

                    <form action="/admin/contact-requests/<%= reqItem.id %>/status" method="POST" class="request-actions-form">
                      <select name="status" required>
                        <option value="new" <%= reqItem.status === 'new' ? 'selected' : '' %>>New</option>
                        <option value="in_progress" <%= reqItem.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                        <option value="done" <%= reqItem.status === 'done' ? 'selected' : '' %>>Done</option>
                      </select>
                      <button type="submit" class="btn">Update</button>
                    </form>
                  </div>
                </td>
              </tr>

              <tr class="request-message-row">
                <td colspan="8">
                  <div class="request-message-box">
                    <strong>Employer message:</strong>
                    <div>
                      <%= reqItem.message %>
                    </div>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state-box">
        No employer contact requests were found.
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>