<%- include('partials/header', { currentPage }) %>

<section class="dashboard-page">
  <div class="dashboard-hero">
    <h2>Admin Dashboard</h2>
    <p>
      Welcome back, <%= user.fullname %>. Get a quick overview of platform activity,
      users, opportunities, and requests from one clean workspace.
    </p>
  </div>

  <section class="stats-grid admin-stats">
    <div class="stat-card admin-stat-card">
      <div class="stat-icon">👥</div>
      <div>
        <h3><%= stats.usersCount %></h3>
        <p>Total Users</p>
      </div>
    </div>

    <div class="stat-card admin-stat-card">
      <div class="stat-icon">💼</div>
      <div>
        <h3><%= stats.opportunitiesCount %></h3>
        <p>Total Opportunities</p>
      </div>
    </div>

    <div class="stat-card admin-stat-card">
      <div class="stat-icon">📨</div>
      <div>
        <h3><%= stats.contactsCount %></h3>
        <p>Contact Messages</p>
      </div>
    </div>
  </section>

  <section class="quick-actions">
    <a href="/crm" class="quick-action-card">
      <span class="action-icon">💬</span>
      <h3>CRM Requests</h3>
      <p>Review employer requests and contact messages.</p>
    </a>

    <a href="/users-management" class="quick-action-card">
      <span class="action-icon">👥</span>
      <h3>Manage Users</h3>
      <p>Review users, roles, and registered accounts.</p>
    </a>

    <a href="/opportunities-management" class="quick-action-card">
      <span class="action-icon">💼</span>
      <h3>Manage Opportunities</h3>
      <p>Manage jobs, internships, and projects.</p>
    </a>

    <a href="/statistics" class="quick-action-card">
      <span class="action-icon">📊</span>
      <h3>View Statistics</h3>
      <p>Analyze platform activity and performance.</p>
    </a>
  </section>

  <section class="recent-activity">
    <div class="section-toolbar">
      <div>
        <h2>Recent Activity</h2>
        <p>Latest platform activity and admin updates.</p>
      </div>
    </div>

    <div class="activity-list">
      <div class="activity-item">
        <span class="activity-icon">👥</span>
        <div>
          <strong><%= stats.usersCount %> users registered</strong>
          <p>Students, graduates, employers, and admins are managed from the Users area.</p>
        </div>
      </div>

      <div class="activity-item">
        <span class="activity-icon">💼</span>
        <div>
          <strong><%= stats.opportunitiesCount %> opportunities available</strong>
          <p>Jobs, internships, and projects are managed from the Opportunities area.</p>
        </div>
      </div>

      <div class="activity-item">
        <span class="activity-icon">📨</span>
        <div>
          <strong><%= stats.contactsCount %> contact messages</strong>
          <p>Contact messages and employer requests are handled inside the CRM area.</p>
        </div>
      </div>
    </div>
  </section>
</section>

<%- include('partials/footer') %>
