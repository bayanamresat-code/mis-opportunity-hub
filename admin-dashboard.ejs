<%- include('partials/header', { currentPage }) %>

<section class="dashboard-page">
  <div class="dashboard-hero">
    <h2>Admin Dashboard</h2>
    <p>Welcome back, <%= user.fullname %>. Monitor platform growth, review core activity, and manage users, opportunities, and contact requests from one clean workspace.</p>
  </div>

  <section class="stats-grid">
    <div class="stat-card">
      <h3><%= stats.usersCount %></h3>
      <p>Total users</p>
    </div>

    <div class="stat-card">
      <h3><%= stats.contactsCount %></h3>
      <p>Contact messages</p>
    </div>

    <div class="stat-card">
      <h3><%= stats.opportunitiesCount %></h3>
      <p>Total opportunities</p>
    </div>
  </section>

  <section class="dashboard-grid">
    <div class="dashboard-card">
      <h3>CRM Workspace</h3>
      <p>Manage users, opportunities, and incoming contact requests from the central CRM view.</p>
      <a href="/crm" class="btn-link">Open CRM</a>
    </div>

    <div class="dashboard-card">
      <h3>Users Overview</h3>
      <p>Track how many users are registered across student, graduate, employer, and admin roles.</p>
    </div>

    <div class="dashboard-card">
      <h3>Opportunity Control</h3>
      <p>Review and update jobs, internships, and projects to keep the platform relevant and current.</p>
    </div>

    <div class="dashboard-card">
      <h3>Inbox Monitoring</h3>
      <p>Stay on top of inbound messages and follow up on important requests through the CRM dashboard.</p>
    </div>
  </section>
</section>

<%- include('partials/footer') %>